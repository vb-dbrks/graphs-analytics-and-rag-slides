# Point npm at Databricks's internal proxy — public npm access is blocked
# inside Databricks infrastructure (Apps runtime, CI, Arca, etc.). See
# go/npm-registry-access / go/pypi-registry-access.
registry=https://npm-proxy.dev.databricks.com/

# Let install succeed when peer-deps don't align (react-cytoscapejs 2.0.0
# declares peers against React 16/17/18; our React 18.3 resolves fine but
# npm 10+ is stricter by default).
legacy-peer-deps=true
